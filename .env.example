# ── Proveedor LLM ──────────────────────────────────────────────────────────
# Opciones: "openai" | "ollama"
LLM_PROVIDER=openai

# Modelo a usar (si no se especifica se usa el default del proveedor)
# OpenAI defaults: gpt-4o-mini
# Ollama  defaults: llama3.1
# LLM_MODEL=gpt-4o-mini

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Ollama ─────────────────────────────────────────────────────────────────
# URL del servidor Ollama (default: http://localhost:11434/v1)
# OLLAMA_BASE_URL=http://localhost:11434/v1
